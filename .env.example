# Copy to .env.local and fill in. Never commit .env or .env.local.

# Server-only — OpenRouter (Claude, Gemini, moderator, summarizer, clarify)
OPENROUTER_API_KEY=

# Optional — override HTTP-Referer for OpenRouter (default: https://$VERCEL_URL on Vercel, else localhost)
OPENROUTER_HTTP_REFERER=

# Server-only — OpenAI (GPT-4o stream in /api/debate)
OPENAI_API_KEY=

# Client — Convex HTTP URL (public by design; use dev URL locally, prod URL on Vercel)
NEXT_PUBLIC_CONVEX_URL=

# Optional — password gate; value is embedded in the client bundle (use a strong password)
NEXT_PUBLIC_ACCESS_PASSWORD=
